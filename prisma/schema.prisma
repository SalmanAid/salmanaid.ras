generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// AUTH & USER MODELS (NextAuth Compatible)
// ==========================================

model User {
  id                      String    @id @default(uuid()) @db.Uuid
  name                    String
  email                   String   @unique
  emailVerified           DateTime?
  phoneVerified           DateTime?
  password                String
  image                   String?
  nik                     String?  @unique
  phone_number            String?
  address                 String?
  identityCard            String?
  identityCardUploadedAt  DateTime?
  institutionCard         String?
  institutionCardUploadedAt DateTime?
  familyCard              String?
  familyCardUploadedAt    DateTime?
  isVerified              Boolean   @default(false)
  verifiedBy              String?
  verificationDate        DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // NextAuth Relations
  accounts         Account[]
  sessions         Session[]

  // Business Logic Relations
  donorFunds       DonorFund[]
  loanApplications LoanApplication[]
  notifications    Notification[]
  roles            UserRole[]

  @@map("users")
  @@index([email])
  @@index([createdAt])
  @@index([isVerified])
}

model Account {
  id                 String  @id @default(uuid()) @db.Uuid
  userId             String  @db.Uuid
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Role {
  id    String     @id @default(uuid()) @db.Uuid
  name  String     @unique
  users UserRole[]
}

model UserRole {
  userId                String                    @db.Uuid
  roleId                String                    @db.Uuid
  verificationStatus    AccountVerificationStatus @default(PENDING)
  verificationMessage   String?
  verificationRequestedAt DateTime                @default(now())
  documentsUpdatedAt    DateTime?
  reviewedAt            DateTime?
  reviewedBy            String?
  role                  Role                      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([verificationStatus])
  @@index([documentsUpdatedAt, verificationRequestedAt])
}

// ==========================================
// BUSINESS LOGIC MODELS
// ==========================================

model DonorFund {
  id           String        @id @default(uuid()) @db.Uuid
  donorId      String        @db.Uuid
  paymentTransactionId String? @unique @db.Uuid
  amount       Decimal       @db.Decimal(12, 2)
  remaining    Decimal       @db.Decimal(12, 2)
  createdAt    DateTime      @default(now())
  donor        User          @relation(fields: [donorId], references: [id], onDelete: Cascade)
  loanFundings LoanFunding[]
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)

  @@index([donorId])
  @@index([createdAt])
}

model LoanApplication {
  id                    String                @id @default(uuid()) @db.Uuid
  borrowerId            String                @db.Uuid
  requestedAmount       Decimal               @db.Decimal(12, 2)
  description           String
  collateralUrl         String?
  collateralDescription String?
  installmentFreq       Int                   @default(4)
  status                LoanApplicationStatus @default(PENDING)
  createdAt             DateTime              @default(now())
  loan                  Loan?
  borrower              User                  @relation(fields: [borrowerId], references: [id], onDelete: Cascade)
  statusHistories       ApplicationStatusHistory[]
  attachments           ApplicationAttachment[]

  @@index([status])
  @@index([borrowerId])
  @@index([createdAt])
}

model Loan {
  id             String          @id @default(uuid()) @db.Uuid
  applicationId  String          @unique @db.Uuid
  approvedAmount Decimal         @db.Decimal(12, 2)
  status         LoanStatus
  approvedAt     DateTime
  dueDate        DateTime
  installmentFreq Int           @default(4)
  application    LoanApplication @relation(fields: [applicationId], references: [id])
  fundings       LoanFunding[]
  repayments     Repayment[]

  @@index([status])
  @@index([status, dueDate])
  @@index([approvedAt])
}

model LoanFunding {
  id          String            @id @default(uuid()) @db.Uuid
  loanId      String            @db.Uuid
  sourceType  FundingSourceType
  donorFundId String?           @db.Uuid
  amount      Decimal           @db.Decimal(12, 2)
  donorFund   DonorFund?        @relation(fields: [donorFundId], references: [id])
  loan        Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([donorFundId])
}

model Repayment {
  id     String          @id @default(uuid()) @db.Uuid
  loanId String          @db.Uuid
  paymentTransactionId String? @unique @db.Uuid
  amount Decimal         @db.Decimal(12, 2)
  paidAt DateTime
  status RepaymentStatus
  loan   Loan            @relation(fields: [loanId], references: [id], onDelete: Cascade)
  paymentTransaction PaymentTransaction? @relation(fields: [paymentTransactionId], references: [id], onDelete: SetNull)

  @@index([loanId])
  @@index([status])
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  type        String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sentAt])
}

model PaymentTransaction {
  id          String              @id @default(uuid()) @db.Uuid
  externalId  String
  referenceId String              @db.Uuid
  category    TransactionCategory
  amount      Decimal             @db.Decimal(12, 2)
  paymentType String
  status      TransactionStatus
  response    Json
  donorFund   DonorFund?
  repayment   Repayment?

  @@index([referenceId, category])
}

model ApplicationStatusHistory {
  id            String    @id @default(uuid()) @db.Uuid
  applicationId String    @db.Uuid
  adminId       String    @db.Uuid
  fromStatus    LoanApplicationStatus
  toStatus      LoanApplicationStatus
  notes         String?
  createdAt     DateTime  @default(now())
  loanApplication LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([createdAt])
}

model ApplicationAttachment {
  id            String    @id @default(uuid()) @db.Uuid
  applicationId String    @db.Uuid
  documentType  String
  fileUrl       String
  uploadedAt    DateTime  @default(now())
  loanApplication LoanApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

// ==========================================
// ENUMS
// ==========================================

enum LoanApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LoanStatus {
  ACTIVE
  PAID
  FORGIVEN
  DEFAULTED
}

enum FundingSourceType {
  DONOR
  INVESTOR
}

enum RepaymentStatus {
  PENDING
  CONFIRMED
}

enum TransactionStatus {
  PENDING
  SETTLEMENT
  EXPIRE
  FAILURE
}

enum TransactionCategory {
  DONATION
  REPAYMENT
}

enum AccountVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
  REVISION_REQUESTED
}
